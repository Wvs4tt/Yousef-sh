    let currentQuestionIndex = 0; 
    const answersState = new Array(questions.length).fill(false); 
 
    const sidebar        = document.getElementById('sidebar');
    const qNumberTitle   = document.getElementById('q-number-title');
    const qText          = document.getElementById('q-text');
    const qOptions       = document.getElementById('q-options');
    const btnNext        = document.getElementById('btn-next');
    const btnSkip        = document.getElementById('btn-skip');
    const qStatsText     = document.getElementById('q-stats-text');
    const questionProgressFill = document.getElementById('question-progress-fill');
    const questionProgressText = document.getElementById('question-progress-text');
    const timeStatsText  = document.getElementById('time-stats-text');
    const timeSlider     = document.getElementById('time-slider');
    const sliderLiveLabel = document.getElementById('slider-live-label');
    const timeProgressFill = document.getElementById('time-progress-fill');
    const timeProgressText = document.getElementById('time-progress-text');
 
    const TOTAL_MINUTES = 120;
    let remainingSeconds = TOTAL_MINUTES * 60;
 
    function updateTimerDisplay() {
        const mins = Math.floor(remainingSeconds / 60);
        timeStatsText.textContent = `الوقت ${mins} / ${TOTAL_MINUTES} (دقيقة)`;
 
        const elapsedSeconds = (TOTAL_MINUTES * 60) - remainingSeconds;
        const percent = Math.min(100, Math.round((elapsedSeconds / (TOTAL_MINUTES * 60)) * 100));
        timeProgressFill.style.width = percent + "%";
        timeProgressText.textContent = percent + "%";
 
        if (mins <= 5) {
            timeStatsText.classList.add('time-warning');
            timeProgressFill.style.backgroundColor = '#e05050';
        } else {
            timeStatsText.classList.remove('time-warning');
            timeProgressFill.style.backgroundColor = '#4caf50';
        }
    }
 
    const timerInterval = setInterval(() => {
        if (remainingSeconds > 0) {
            remainingSeconds--;
            updateTimerDisplay();
            if (!isDragging) {
                timeSlider.value = Math.ceil(remainingSeconds / 60);
                sliderLiveLabel.textContent = Math.ceil(remainingSeconds / 60) + ' دقيقة';
            }
        } else {
            clearInterval(timerInterval);
            timeStatsText.textContent = 'انتهى الوقت!';
            timeStatsText.classList.add('time-warning');
            timeProgressFill.style.width = '100%';
            timeProgressText.textContent = '100%';
        }
    }, 1000);
 
    let isDragging = false;
 
    timeSlider.addEventListener('input', () => {
        isDragging = true;
        const newMins = parseInt(timeSlider.value);
        sliderLiveLabel.textContent = newMins + ' دقيقة';
    });
 
    timeSlider.addEventListener('change', () => {
        const newMins = parseInt(timeSlider.value);
        remainingSeconds = newMins * 60;
        updateTimerDisplay();
        isDragging = false;
    });
 
    timeSlider.addEventListener('touchend', () => {
        const newMins = parseInt(timeSlider.value);
        remainingSeconds = newMins * 60;
        updateTimerDisplay();
        isDragging = false;
    });
 
    function loadQuestion(index) {
        currentQuestionIndex = index;
        const q = questions[index];
        const displayIndex = index + 1; 
 
        qNumberTitle.textContent = "س." + displayIndex;
        qText.textContent = q.text;
 
        qOptions.innerHTML = ''; 
        q.options.forEach((option, i) => {
            const label = document.createElement('label');
            label.className = 'option';
            label.innerHTML = `<input type="radio" name="answer" value="${i}"> ${option}`;
            qOptions.appendChild(label);
        });
 
        updateSidebar();
        updateStats();
    }
 
    function updateSidebar() {
        sidebar.innerHTML = '';
        for (let i = 0; i < questions.length; i++) {
            const div = document.createElement('div');
            div.className = 'q-number';
            div.textContent = i + 1;
            if (i === currentQuestionIndex) {
                div.classList.add('q-blue'); 
            } else if (answersState[i]) {
                div.classList.add('q-green'); 
            } else {
                div.classList.add('q-gray'); 
            }
            div.onclick = () => loadQuestion(i); 
            sidebar.appendChild(div);
        }
    }
 
    function updateStats() {
        const displayIndex = currentQuestionIndex + 1;
        qStatsText.textContent = `الأسئلة ${displayIndex} / ${questions.length}`;
        const progressPercent = Math.round((displayIndex / questions.length) * 100);
        questionProgressFill.style.width = progressPercent + "%";
        questionProgressText.textContent = progressPercent + "%";
    }
 
    btnNext.onclick = () => {
        const selectedOption = document.querySelector('input[name="answer"]:checked');
        if (selectedOption) {
            answersState[currentQuestionIndex] = true; 
        }
        if (currentQuestionIndex < questions.length - 1) {
            loadQuestion(currentQuestionIndex + 1); 
        } else {
            alert("لقد وصلت إلى نهاية الاختبار!");
            updateSidebar(); 
        }
    };
 
    btnSkip.onclick = () => {
        if (currentQuestionIndex < questions.length - 1) {
            loadQuestion(currentQuestionIndex + 1); 
        } else {
            alert("لا يوجد أسئلة أخرى لتخطيها.");
        }
    };
 
    loadQuestion(0);
