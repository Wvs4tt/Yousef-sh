<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="اختبار قانون الضمان">
    
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#1e2029">
 
    <title>اختبار تفاعلي: قانون الضمان العيني والشخصي</title>
    <style>
        body {
            background-color: #22252d;
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            overflow-x: hidden;
            overscroll-behavior-y: contain; 
        }
        .container {
            width: 100%;
            max-width: 600px;
            background-color: #1e2029;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            border-left: 1px solid #333;
            border-right: 1px solid #333;
        }
        header {
            padding: 15px;
            border-bottom: 1px solid #3b3f4a;
            background-color: #2a2d38;
        }
        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        .student-name {
            font-size: 11px;
            color: #ccc;
            text-align: right;
        }
        .student-name span {
            display: block;
            color: #fff;
            font-size: 13px;
            font-weight: bold;
            margin-top: 3px;
        }
        .top-buttons {
            display: flex;
            gap: 5px;
        }
        .top-buttons button {
            background: transparent;
            border: 1px solid #777;
            color: #fff;
            padding: 5px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 12px;
            font-weight: bold;
        }
        .stats-area {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 12px;
            margin-bottom: 5px;
        }
        .stats-text {
            text-align: right;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .progress-section {
            width: 70%;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }
        .progress-bar-container {
            display: flex;
            align-items: center;
            width: 100%;
        }
        .progress-bar-container span {
            width: 35px;
            text-align: left;
            margin-right: 8px;
        }
        .progress-bar {
            background-color: #3b3f4a;
            height: 5px;
            flex: 1; 
            border-radius: 3px;
            overflow: hidden;
        }
        .progress-fill {
            background-color: #4caf50;
            height: 100%;
            width: 0%;
            transition: width 0.3s ease;
        }
        .main-content {
            display: flex;
            flex: 1;
            position: relative;
        }
        .sidebar {
            width: 42px;
            background-color: #1a1c23;
            border-left: 1px solid #3b3f4a;
            padding: 10px 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-y: auto;
        }
        .q-number {
            width: 28px;
            height: 28px;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 4px;
            margin-bottom: 5px;
            font-size: 11px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
            flex-shrink: 0;
        }
        .q-green { background-color: #4caf50; color: white; }
        .q-blue { 
            background-color: #1e78d9; 
            color: white; 
            position: relative;
        }
        .q-blue::before {
            content: "";
            position: absolute;
            left: -7px;
            top: 50%;
            transform: translateY(-50%);
            width: 0;
            height: 0;
            border-top: 7px solid transparent;
            border-bottom: 7px solid transparent;
            border-right: 8px solid #1e78d9;
        }
        .q-gray { background-color: #48546a; color: white; }
        .question-area {
            flex: 1;
            padding: 15px;
            padding-bottom: 80px;
        }
        .q-header {
            display: flex;
            justify-content: space-between;
            color: #6a9ce0;
            font-size: 13px;
            border-bottom: 1px solid #3b3f4a;
            padding-bottom: 8px;
            margin-bottom: 12px;
        }
        .question-text {
            font-size: 15px;
            font-weight: bold;
            margin-bottom: 18px;
            line-height: 1.6;
        }
        .options {
            display: flex;
            flex-direction: column;
            gap: 9px;
        }
        .option {
            background-color: #2b2f3a;
            border: 1px solid #3b3f4a;
            padding: 12px;
            border-radius: 5px;
            display: flex;
            align-items: center;
            cursor: pointer;
            transition: background 0.2s, border-color 0.2s;
        }
        .option:hover {
            background-color: #353a47;
            border-color: #555;
        }
        .option input[type="radio"] {
            -webkit-appearance: none;
            appearance: none;
            margin: 0 0 0 12px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 2px solid #6b7280;
            background-color: transparent;
            cursor: pointer;
            flex-shrink: 0;
            position: relative;
            transition: border-color 0.15s, background-color 0.15s;
        }
        .option input[type="radio"]:checked {
            border-color: #1e78d9;
            background-color: transparent;
        }
        .option input[type="radio"]:checked::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 10px;
            height: 10px;
            border-radius: 50%;
            border: 2px solid #1e78d9;
            background-color: transparent;
        }
 
        footer {
            padding: 12px 15px;
            border-top: 1px solid #3b3f4a;
            background-color: #1e2029;
            display: flex;
            gap: 8px;
            position: sticky;
            bottom: 0;
            width: 100%;
            box-sizing: border-box;
            z-index: 10;
        }
        footer button {
            padding: 12px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            border: none;
            transition: opacity 0.2s;
        }
        footer button:active { opacity: 0.8; }
        .btn-secondary {
            flex: 1;
            background-color: transparent;
            border: 1px solid #777;
            color: white;
        }
        .btn-primary {
            flex: 2;
            background-color: #1e78d9;
            color: white;
        }
 
        .time-slider-bar {
            background-color: #23262f;
            border-top: 1px solid #3b3f4a;
            padding: 12px 15px 16px;
            width: 100%;
            box-sizing: border-box;
        }
        .slider-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }
        .slider-label-text {
            font-size: 11px;
            color: #888;
        }
        .slider-live-value {
            font-size: 12px;
            font-weight: bold;
            color: #fff;
            background: #1e78d9;
            padding: 2px 8px;
            border-radius: 10px;
        }
        input[type="range"]#time-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 5px;
            background: #3b3f4a;
            border-radius: 3px;
            outline: none;
            cursor: pointer;
        }
        input[type="range"]#time-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #1e78d9;
            cursor: pointer;
            border: 2px solid #fff;
            box-shadow: 0 0 6px rgba(30,120,217,0.7);
        }
        input[type="range"]#time-slider::-moz-range-thumb {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #1e78d9;
            cursor: pointer;
            border: 2px solid #fff;
        }
        .slider-ends {
            display: flex;
            justify-content: space-between;
            font-size: 10px;
            color: #555;
            margin-top: 3px;
        }
 
        .time-warning { color: #e05050 !important; }
    </style>
</head>
<body>
 
<div class="container">
    <header>
        <div class="top-header">
            <div class="student-name">
                اسم الطالب
                <span>Yousef Shaya Ayidh Alqhtani</span>
            </div>
            <div class="top-buttons">
                <button>الملخص</button>
                <button>الأدوات</button>
            </div>
        </div>
        
        <div class="stats-area">
            <div class="stats-text">
                <div id="q-stats-text">الأسئلة -- / --</div>
                <div id="time-stats-text">الوقت 120 / 120 (دقيقة)</div>
            </div>
            <div class="progress-section">
                <div class="progress-bar-container">
                    <div class="progress-bar"><div class="progress-fill" id="question-progress-fill"></div></div>
                    <span id="question-progress-text">--%</span>
                </div>
                <div class="progress-bar-container">
                    <div class="progress-bar"><div class="progress-fill" id="time-progress-fill" style="width: 0%;"></div></div>
                    <span id="time-progress-text">0%</span>
                </div>
            </div>
        </div>
    </header>
 
    <div class="main-content">
        <div class="sidebar" id="sidebar"></div>
        <div class="question-area" id="question-area">
            <div class="q-header">
                <span id="q-number-title">س.--</span>
                <span>اختيارات متعددة</span>
                <span id="q-grade">درجة السؤال: 1.00</span>
            </div>
            <div class="question-text" id="q-text">جاري تحميل السؤال...</div>
            <div class="options" id="q-options"></div>
        </div>
    </div>
 
    <footer>
        <button class="btn-secondary">علامة السؤال</button>
        <button class="btn-secondary" id="btn-skip">تخطي</button>
        <button class="btn-primary" id="btn-next">التالي</button>
    </footer>
 
    <div class="time-slider-bar">
        <div class="slider-top">
